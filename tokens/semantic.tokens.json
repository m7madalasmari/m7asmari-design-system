          "   الوضع الداكن — يعيد تعريف الطبقة الدلالية فقط (.dark على عنصر .ds الجذري)",
          "   القيم الداكنة مضبوطة يدويًا (لوحة باردة) ومحفوظة كما كانت بصريًا.",
          "   ============================================================================ */"
        ],
        "lines": [
          {
            "decls": [
              "background",
              "surface",
              "surface-muted",
              "surface-elevated"
            ]
          },
          {
            "decls": [
              "text-primary",
              "text-secondary",
              "text-muted"
            ]
          },
          {
            "decls": [
              "border",
              "border-strong"
            ]
          },
          {
            "decls": [
              "brand",
              "brand-hover",
              "brand-ink",
              "brand-soft"
            ]
          },
          {
            "decls": [
              "success-ink",
              "success-soft"
            ]
          },
          {
            "decls": [
              "warning-ink",
              "warning-soft"
            ]
          },
          {
            "decls": [
              "danger-ink",
              "danger-soft"
            ]
          },
          {
            "decls": [
              "info-ink",
              "info-soft"
            ]
          },
          {
            "raw": "  /* حلقة تركيز أوضح على الخلفيات الداكنة (لون العلامة الداكن + شفافية أعلى) */"
          },
          {
            "decls": [
              "focus-ring"
            ]
          }
        ]
      }
    },
