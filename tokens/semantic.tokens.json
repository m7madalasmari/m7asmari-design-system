{
  "$description": "M7asmari Semantic Tokens (Layer 2/4) — DTCG / W3C Design Tokens source of truth. Regenerates tokens/semantic.css byte-identically via scripts/build-tokens.py. The semantic vocabulary consumed by the system/components, built on the primitive layer; defined across multiple selectors (:root, .dark, .ds.acc-green, .ds.acc-red, .ds.sharp). $value holds the exact CSS value (var()/hex/rgba verbatim); $extensions.com.m7asmari.css captures per-block selector, declaration order, exact declaration text and interleaved comments so output is byte-reproducible. Values copied verbatim from the previous CSS (zero visual change).",
  "$extensions": {
    "com.m7asmari.css": {
      "format": "blocks",
      "header": [
        "/* ============================================================================",
        "   M7asmari — Semantic Tokens (Layer 2 / 4)",
        "   ----------------------------------------------------------------------------",
        "   المفردات الدلالية التي يستهلكها النظام والمكوّنات. مبنية من primitive.css.",
        "   هذه هي مصدر الحقيقة للألوان في الواجهة — لا تستخدم primitives داخل المكوّنات.",
        "   القيم مطابقة بصريًا للإصدار السابق (tokens.css/themes.css).",
        "   ============================================================================ */"
      ],
      "blockOrder": [
        "block-0",
        "block-1",
        "block-2",
        "block-3",
        "block-4"
      ]
    }
  },
  "block-0": {
    "$extensions": {
      "com.m7asmari.css": {
        "selector": ":root",
        "lines": [
          {
            "raw": "  /* ===== الأسطح والخلفيات ===== */"
          },
          {
            "decls": [
              "background"
            ],
            "trailing": "   /* خلفية الصفحة */"
          },
          {
            "decls": [
              "surface"
            ],
            "trailing": "    /* بطاقات/لوحات */"
          },
          {
            "decls": [
              "surface-muted"
            ],
            "trailing": "  /* سطح خافت ثانوي */"
          },
          {
            "decls": [
              "surface-elevated"
            ],
            "trailing": "  /* سطح أعلى/محدّد */"
          },
          {
            "blank": true
          },
          {
            "raw": "  /* ===== النصوص ===== */"
          },
          {
            "decls": [
              "text-primary"
            ]
          },
          {
            "decls": [
              "text-secondary"
            ]
          },
          {
            "decls": [
              "text-muted"
            ]
          },
          {
            "blank": true
          },
          {
            "raw": "  /* ===== الحدود ===== */"
          },
          {
            "decls": [
              "border"
            ],
            "trailing": "             /* قيمة مضبوطة يدويًا (بين neutral-200/300) */"
          },
          {
            "decls": [
              "border-strong"
            ]
          },
          {
            "blank": true
          },
          {
            "raw": "  /* ===== العلامة (Brand) — قابلة للتخصيص ===== */"
          },
          {
            "decls": [
              "brand"
            ]
          },
          {
            "decls": [
              "brand-hover"
            ]
          },
          {
            "decls": [
              "brand-ink"
            ]
          },
          {
            "decls": [
              "brand-soft"
            ]
          },
          {
            "decls": [
              "focus-ring"
            ]
          },
          {
            "blank": true
          },
          {
            "raw": "  /* ===== ألوان الحالة (Status) — كلٌّ: base / ink (نص) / soft (تعبئة) ===== */"
          },
          {
            "decls": [
              "success",
              "success-ink",
              "success-soft"
            ]
          },
          {
            "decls": [
              "warning",
              "warning-ink",
              "warning-soft"
            ]
          },
          {
            "decls": [
              "danger",
              "danger-ink",
              "danger-soft"
            ]
          },
          {
            "decls": [
              "info",
              "info-ink",
              "info-soft"
            ]
          }
        ]
      }
    },
    "background": {
      "$value": "var(--neutral-50)",
      "$extensions": {
        "com.m7asmari.css": {
          "decl": "--background:    var(--neutral-50);"
        }
      }
    },
    "surface": {
      "$value": "var(--neutral-0)",
      "$extensions": {
        "com.m7asmari.css": {
          "decl": "--surface:       var(--neutral-0);"
        }
      }
    },
    "surface-muted": {
